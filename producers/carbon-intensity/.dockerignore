# ============================================================================
# .dockerignore for the carbon-intensity producer
# Everything matched here is excluded from `docker build` context.
# Keeps build fast and prevents accidentally shipping secrets/dev tooling.
# ============================================================================

# Python
__pycache__/
*.py[cod]
*.so
.Python
.venv/
venv/
.uv/
uv.lock

# Testing / linting
tests/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp

# Git
.git/
.gitignore
.gitattributes

# Docs
README.md
*.md

# Local-only
.env
.env.*
secrets/
